# ============================================================================
# Career Intelligence Portal - Backend Environment Variables
# ============================================================================
# Copy this file to .env and update with your actual configuration

# Server Configuration
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ============================================================================
# Database Configuration
# ============================================================================
# MongoDB - Local Development
MONGODB_URI=mongodb://localhost:27017/career_intelligence

# ============================================================================
# Authentication
# ============================================================================
# JWT Secret - CHANGE THIS IN PRODUCTION!
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_12345
JWT_EXPIRE=7d

# Firebase Configuration (Server-side)
FIREBASE_API_KEY=AIzaSyCmU9yKvzZWfXcQfYBknYaPaZFKoae0-KA
FIREBASE_AUTH_DOMAIN=userauth-bb93a.firebaseapp.com
FIREBASE_PROJECT_ID=userauth-bb93a
FIREBASE_STORAGE_BUCKET=userauth-bb93a.firebasestorage.app

# ============================================================================
# Email Configuration (for email verification, password reset, etc.)
# ============================================================================
# Gmail Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM=noreply@careerportal.com

# ============================================================================
# External APIs
# ============================================================================
# Coding Platform APIs (for fetching user stats)
LEETCODE_API_KEY=your_leetcode_api_key
CODECHEF_API_KEY=your_codechef_api_key
CODEFORCES_API_KEY=your_codeforces_api_key

# ============================================================================
# File Upload Configuration
# ============================================================================
MAX_FILE_SIZE=5242880  # 5MB in bytes
UPLOAD_PATH=./uploads
ALLOWED_FILE_TYPES=pdf,doc,docx

# ============================================================================
# Application Configuration
# ============================================================================
SESSION_TIMEOUT=3600000  # 1 hour in milliseconds
LOG_LEVEL=debug

# ============================================================================
# AI/ML Configuration
# ============================================================================
# Add keys for AI services like OpenAI, Hugging Face, etc.
OPENAI_API_KEY=your_openai_key_here

