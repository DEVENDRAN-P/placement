# ============================================================================
# Career Intelligence Portal - Backend Environment Variables
# ============================================================================
# Copy this file to .env and update with your actual configuration
# IMPORTANT: Never commit .env file with real secrets to git!

# Server Configuration
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ============================================================================
# Database Configuration
# ============================================================================
# MongoDB - Using MongoDB Atlas for production
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGODB_URI=mongodb+srv://username:password@your-cluster.mongodb.net/career_intelligence?retryWrites=true&w=majority

# ============================================================================
# Authentication
# ============================================================================
# JWT Secret - CHANGE THIS IN PRODUCTION! Generate a strong random string
JWT_SECRET=generate-a-strong-random-string-at-least-32-characters
JWT_EXPIRE=7d

# Firebase Configuration (Server-side)
# Get these from Firebase Console -> Project Settings
FIREBASE_API_KEY=your_firebase_api_key_from_console
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app

# ============================================================================
# Email Configuration (for email verification, password reset, etc.)
# ============================================================================
# Gmail Configuration with App Password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_specific_password_not_main_password
EMAIL_FROM=noreply@careerportal.com

# ============================================================================
# External APIs
# ============================================================================
# OpenAI API Key (for AI features)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Coding Platform APIs (for fetching user stats)
# These are optional - can be empty if using public endpoints
LEETCODE_API_KEY=optional_if_using_public
CODECHEF_API_KEY=optional_if_using_public  
CODEFORCES_API_KEY=optional_if_using_public

# ============================================================================
# File Upload Configuration
# ============================================================================
MAX_FILE_SIZE=5000000
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880  # 5MB in bytes
UPLOAD_PATH=./uploads
ALLOWED_FILE_TYPES=pdf,doc,docx

# ============================================================================
# Application Configuration
# ============================================================================
SESSION_TIMEOUT=3600000  # 1 hour in milliseconds
LOG_LEVEL=debug

# ============================================================================
# AI/ML Configuration
# ============================================================================
# Add keys for AI services like OpenAI, Hugging Face, etc.
OPENAI_API_KEY=your_openai_key_here

