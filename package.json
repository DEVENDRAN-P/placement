    "bcryptjs": "^2.4.3",
    "chart.js": "^4.4.0",
    "cheerio": "^1.0.0-rc.12",
    "compromise": "^14.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.6.0",
    "ml-matrix": "^6.11.0",
    "ml-regression": "^5.0.0",
    "moment": "^2.29.4",
    "mongoose": "^7.5.0",
    "multer": "^1.4.5-lts.1",
    "natural": "^6.5.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.9.4",
